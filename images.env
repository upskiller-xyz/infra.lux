# Release-manifest för CPU-tjänsterna (topologi A & B).
#
# Källa till sanning för VAD som körs i prod. Pinna EXAKTA taggar (semver eller
# git-describe) — aldrig 'latest'/'edge'. Release = ändra tagg + redeploy.
# Rollback = sätt tillbaka föregående tagg.
#
# GPU-modellen styrs separat i modal/model_gpu/model.env (egen livscykel).

REGISTRY=rg.fr-par.scw.cloud
NAMESPACE=upskiller

LUX_TAG=0.1.0
ENCODER_TAG=0.1.0
MERGER_TAG=0.1.0
OBSTRUCTION_TAG=0.1.0
STATS_TAG=0.1.0
