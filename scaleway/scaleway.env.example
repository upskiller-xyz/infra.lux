# Topologi B — Scaleway Serverless. Kopiera till scaleway.env och fyll i.
# scw-CLI läser SCW_*-variablerna; de övriga används av deploy-serverless.sh.

# ── Scaleway-auth (IAM) ───────────────────────────────────────────────────────
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_REGION=fr-par

# ── Serverless container ──────────────────────────────────────────────────────
SCW_NAMESPACE_NAME=lux-cpu
CONTAINER_NAME=cpu-pipeline
CONTAINER_IMAGE=rg.fr-par.scw.cloud/lux-nsp/server-cpu-pipeline:edge
CONTAINER_PORT=8080
CONTAINER_CPU_LIMIT=2000      # millicpu (2000 = 2 vCPU)
CONTAINER_MEMORY_LIMIT=4096   # MB
MIN_SCALE=1                   # dagläge; cron sänker till 0 på natten
MAX_SCALE=5

# ── GPU-inferens (konsumeras av lux) ──────────────────────────────────────────
MODEL_SERVICE_URL=https://stasya00--upskiller-model-inferenceservice-web.modal.run
MODAL_KEY=wk-...
MODAL_SECRET=ws-...
