# GPU-inferensens egen livscykel (oberoende av CPU-tjänsternas images.env).
#
# Modal-appen byggs från server_model-källkod vid `modal deploy` (den bakar in
# modeller i imagen) — den pullar INTE en registry-tagg. Därför pinnar vi här
# en git-ref i server_model, inte en docker-tagg.

# Git-ref i server_model att deploya (tag, branch eller sha).
MODEL_REF=master

# Var server_model-repot ligger lokalt (deploy.sh checkar ut MODEL_REF här).
# I CI klonas det i stället från github.com/upskiller-xyz/server_model.
SERVER_MODEL_DIR=../../../server_model

# Modal-workspace (för endpoint-URL:en som konsumenterna pekar på).
# MODAL_WORKSPACE=upskiller
