# Topologi B (Scaleway Serverless) — runtime-env. Kopiera till serverless.env och fyll i.
# CPU-tjänsternas taggar kommer från ../images.env (separat fil).

# GPU-inferens: peka på den fristående Modal-deployen (se modal/model_gpu/).
MODEL_SERVICE_URL=https://<workspace>--upskiller-model-inferenceservice-web.modal.run
MODAL_KEY=wk-...
MODAL_SECRET=ws-...

# Auth in mot gateway.
AUTH_TYPE=token
# API_TOKEN=...
