# Topologi A (VM) — runtime-env. Kopiera till vm.env och fyll i.
# CPU-tjänsternas BILD-TAGGAR ligger separat i ../images.env (pinnade i prod).

# ── Inferens på Modal (det fristående GPU-deployen, se modal/model_gpu/) ──────
# Peka på den deployade Modal-endpointen. *.modal.run auto-detekteras och
# server-lux bifogar Modal-Key / Modal-Secret automatiskt.
MODEL_SERVICE_URL=https://<workspace>--upskiller-model-inferenceservice-web.modal.run
MODAL_KEY=wk-...
MODAL_SECRET=ws-...

# ── Scaleway Container Registry (för att PULLA privata bilder) ────────────────
# Ersätter det gamla GITHUB_TOKEN-flödet: vi klonar inte källkod längre, vi
# pullar färdiga bilder. deploy-vm.sh gör `docker login` med dessa.
# SCW_REGISTRY_USER=nologin
# SCW_SECRET_KEY=your-scaleway-secret-key

# ── Cloudflare (används av setup-cloudflare.sh för DNS + TLS) ─────────────────
DOMAIN=api.yourdomain.com
# CF_API_TOKEN=...        # token med Zone:DNS:Edit + Zone Settings:Edit
# CF_ZONE_ID=...          # zone-id för yourdomain.com
# CF_ORIGIN_CA_KEY=...    # Origin CA Key (behövs bara för att auto-utfärda cert)
# SERVER_IP=              # valfritt; auto-detekteras om tomt

# ── Publik API-auth (inkommande) ──────────────────────────────────────────────
# none = öppet; token = kräver `Authorization: Bearer <API_TOKEN>`; auth0 = JWT (prod).
AUTH_TYPE=auth0
# När AUTH_TYPE=token:
# API_TOKEN=your_public_api_token
# När AUTH_TYPE=auth0 (krävs — servern startar inte utan domain+audience):
AUTH0_DOMAIN=upskiller.eu.auth0.com
AUTH0_AUDIENCE=https://lux-api.upskiller.xyz
AUTH0_ALGORITHMS=RS256

# ── Per-tjänst resurser & workers ─────────────────────────────────────────────
# Obstruction är tyngsta CPU-tjänsten: server-lux skickar en request per fönster
# och tjänsten beräknar alla 64 riktningar internt (vektoriserad ray casting).
OBSTRUCTION_WORKERS=4
OBSTRUCTION_THREADS=2
OBSTRUCTION_CPUS=4
OBSTRUCTION_MEM=4g

LUX_WORKERS=2
LUX_THREADS=8
LUX_CPUS=2
LUX_MEM=2g

ENCODER_WORKERS=2
ENCODER_THREADS=4
ENCODER_CPUS=2
ENCODER_MEM=2g

MERGER_WORKERS=2
MERGER_THREADS=4
MERGER_CPUS=1
MERGER_MEM=1g

STATS_WORKERS=1
STATS_THREADS=4
STATS_CPUS=1
STATS_MEM=1g

# ── Performance / runtime tuning (CPU-only box) ───────────────────────────────
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
OMP_NUM_THREADS=1
LOG_LEVEL=INFO
